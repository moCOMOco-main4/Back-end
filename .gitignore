cat > .gitignore << 'EOF'
# 환경 변수 파일 (비밀 정보)
.env

# Python 바이트코드
__pycache__/
*.py[cod]
*$py.class

# Django 로컬 DB (개발용 SQLite)
db.sqlite3
db.sqlite3-journal

# Django 로그 & 커버리지
*.log
*.pot
*.pyc
local_settings.py
media

# Python 패키지 메타데이터
*.egg-info/
pip-log.txt
pip-delete-this-directory.txt
.installed.cfg
*.egg
MANIFEST

# Python 가상환경
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# 정적·미디어 파일
static/
media/

# IDE 및 에디터 설정
.idea/
*.iml
.vscode/

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
EOF